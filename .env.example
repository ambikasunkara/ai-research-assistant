# ==============================================================================
# AI Research Assistant - Environment Configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ==============================================================================

# ---- Google Gen AI / Vertex credentials -------------------------------------
# Set to "1" (True) to route through Vertex AI, or "0" (False) to use the
# Gemini Developer API directly with GOOGLE_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=your-gemini-api-key-here

# Only required when GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ---- Model configuration -----------------------------------------------------
# Model used for the heavier reasoning agents (orchestrator, research, fact-check)
MODEL_PRO=gemini-2.5-pro
# Model used for lighter, higher-throughput agents (search, summarization, citations)
MODEL_FLASH=gemini-2.5-flash

# ---- MCP Server ---------------------------------------------------------------
# "stdio" launches the MCP server as a local subprocess (recommended default).
# "streamable-http" runs the MCP server as a standalone network service.
MCP_TRANSPORT=stdio
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8765
MCP_SERVER_COMMAND=python
MCP_SERVER_MODULE=ai_research_assistant.mcp_server

# ---- Application / API server --------------------------------------------------
APP_NAME=ai-research-assistant
API_HOST=0.0.0.0
API_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# API key(s) required to call the FastAPI layer. Comma-separated list supported.
RESEARCH_API_KEYS=change-me-dev-key

# ---- Security checkpoint -------------------------------------------------------
MAX_INPUT_CHARS=4000
RATE_LIMIT_PER_MINUTE=20
BLOCK_PROMPT_INJECTION=1

# ---- Human-in-the-loop approval -------------------------------------------------
APPROVAL_TIMEOUT_SECONDS=1800
REQUIRE_HUMAN_APPROVAL=1

# ---- Audit logging ---------------------------------------------------------------
AUDIT_LOG_DIR=./logs
AUDIT_LOG_FILE=audit.log.jsonl
LOG_LEVEL=INFO

# ---- Report output ---------------------------------------------------------------
REPORTS_OUTPUT_DIR=./reports
MAX_PAPERS_PER_QUERY=8
